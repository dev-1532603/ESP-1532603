<UserControl x:Class="ManagerApp.View.ConfigurationV"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ManagerApp.View"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodel="clr-namespace:ManagerApp.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:ConfigurationVM}"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <materialDesign:Card Margin="10" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Titre  -->
            <TextBlock Grid.Row="0"
                       Margin="5"
                       HorizontalAlignment="Center"
                       FontSize="18"
                       FontWeight="Bold"
                       Text="Configuration de l'API" />

            <!--  TextBox URL  -->
            <StackPanel Grid.Row="1"
                        Margin="5"
                        Orientation="Vertical">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Margin="10"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="URL de l'API" />
                    <TextBox Width="350"
                             materialDesign:HintAssist.Hint="https://monapi.exemple.com"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>



            </StackPanel>

            <!--  Boutons  -->
            <StackPanel Grid.Row="2"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                <!--<Button Margin="5"
                        Background="Red"
                        Command="{Binding CancelCommand}"
                        Content="Annuler"
                        Foreground="White"
                        Style="{StaticResource MaterialDesignRaisedButton}" />-->

                <Button Margin="5"
                        Background="Green"
                        Command="{Binding SaveConfigCommand}"
                        Content="Enregistrer"
                        Foreground="White"
                        Style="{StaticResource MaterialDesignRaisedButton}" />
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
