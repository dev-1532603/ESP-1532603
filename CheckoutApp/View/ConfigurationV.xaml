<UserControl x:Class="CheckoutApp.View.ConfigurationV"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CheckoutApp.View"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodel="clr-namespace:CheckoutApp.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:ConfigurationVM}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <materialDesign:Card Margin="10" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Titre -->
            <TextBlock Grid.Row="0"
                       Text="Configuration de l'API"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20" />

            <!-- TextBox URL -->
            <StackPanel Grid.Row="1"
                        Orientation="Vertical"
                        Margin="0,0,0,20">
                <TextBlock Text="URL de l'API"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5" />

                <TextBox Width="350"
                         materialDesign:HintAssist.Hint="https://monapi.exemple.com"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <!-- Boutons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Margin="5,0"
                        Background="Red"
                        Foreground="White"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Content="Annuler" />

                <Button Margin="5,0"
                        Background="Green"
                        Foreground="White"
                        Command="{Binding SaveConfigCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Content="Enregistrer" />
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>
