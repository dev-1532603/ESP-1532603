<UserControl x:Class="SelfCheckoutApp.View.ConfigurationV"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SelfCheckoutApp.View"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodel="clr-namespace:SelfCheckoutApp.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:ConfigurationVM}"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Carte centrée  -->
        <materialDesign:Card Width="460"
                             Margin="20"
                             Padding="30"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             materialDesign:ElevationAssist.Elevation="Dp4">
            <StackPanel Orientation="Vertical">

                <!--  En-tête avec icône  -->
                <StackPanel HorizontalAlignment="Center"
                            Orientation="Vertical"
                            Margin="10">
                    <materialDesign:PackIcon Kind="LinkVariant"
                                            Width="48"
                                            Height="48"
                                            HorizontalAlignment="Center"
                                            Foreground="{DynamicResource PrimaryHueMidBrush}" />
                    <TextBlock Margin="10"
                               HorizontalAlignment="Center"
                               FontSize="20"
                               FontWeight="Bold"
                               Text="Configuration de l'API" />
                </StackPanel>

                <!--  Bloc d'information  -->
                <Border Margin="0,10"
                        Padding="14"
                        Background="{DynamicResource MaterialDesignChipBackground}"
                        CornerRadius="6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                Width="20"
                                                Height="20"
                                                Margin="0,2,10,0"
                                                VerticalAlignment="Top"
                                                Foreground="{DynamicResource PrimaryHueMidBrush}" />
                        <TextBlock FontSize="13"
                                   Foreground="{DynamicResource MaterialDesignBody}"
                                   TextWrapping="Wrap"
                                   MaxWidth="360">
                            <Run Text="Entrez l'URL de base de votre API (ex. : " />
                            <Run FontStyle="Italic" Foreground="Gray" Text="https://monapi.exemple.com" />
                            <Run Text="). Cette adresse sera utilisée pour toutes les communications avec le serveur." />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!--  Champ URL  -->
                <TextBox Margin="0,0,0,24"
                         materialDesign:HintAssist.Hint="https://monapi.exemple.com/api/"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" />

                <!--  Bouton Enregistrer  -->
                <Button HorizontalAlignment="Stretch"
                        Command="{Binding SaveConfigCommand}"
                        Foreground="White"
                        Background="Green"
                        Style="{StaticResource MaterialDesignRaisedButton}"
>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave"
                                                Width="18"
                                                Height="18"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center" />
                        <TextBlock Text="Enregistrer la configuration"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
